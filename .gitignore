# .vscode/settings.json # Already custom-configured in the project

# Unity3D generated meta files
/*.pidb.meta
/*.syncproj.meta

# Unity3D Generated File Groups
sysinfo.txt

# Builds
*.apk
*.unitypackage
*.app

